@baseUrl = http://localhost:5002

# --------------
# SYNC - CREATE
# --------------

### Create Sync - without expiration date(default: 3days)
POST {{baseUrl}}/api/sync
Content-Type: application/json

{
  "title": "Test Sync - default expiry",
  "timeZone": "Asia/Seoul",
  "timeSelector": [
    {
      "date": "2026-04-01",
      "startTime": "2026-04-01T09:00:00.000Z",
      "endTime": "2026-04-01T11:00:00.000Z"
    }
  ],
  "leaderPasscode": "1111"
}

### Create Sync
POST http://localhost:5002/api/sync
Content-Type: application/json

{
  "title": "Test Sync - custom expiry",
  "timeZone": "Asia/Seoul",
  "expiresAt": "2026-03-17T00:00:00.000Z",
  "timeSelector": [
    {
      "date": "2026-04-01",
      "startTime": "2026-04-01T09:00:00.000Z",
      "endTime": "2026-04-01T11:00:00.000Z"
    }
  ],
  "leaderPasscode": "1111"
}

### Create Sync - Test(SYNC_EXPIRED)
POST http://localhost:5002/api/sync
Content-Type: application/json

{
  "title": "Test Sync - custom expiry",
  "timeZone": "Asia/Seoul",
  "expiresAt": "2026-03-15T00:00:00.000Z",
  "timeSelector": [
    {
      "date": "2026-04-01",
      "startTime": "2026-04-01T09:00:00.000Z",
      "endTime": "2026-04-01T11:00:00.000Z"
    }
  ],
  "leaderPasscode": "1111"
}

